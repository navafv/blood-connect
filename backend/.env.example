# SECURITY
SECRET_KEY=my-super-secret-local-dev-key-123
DEBUG=True

# ROUTING
# Note: No spaces after commas!
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# DATABASE (Uncomment and fill out if testing PostgreSQL locally)
# DB_NAME=bloodconnect_db
# DB_USER=postgres
# DB_PASSWORD=my_password
# DB_HOST=localhost
# DB_PORT=5432

# EMAIL
SENDGRID_API_KEY=your_sendgrid_key_here

# REDIS
REDIS_URL=redis://localhost:6379/0

# AWS S3 CONFIGURATION (For Media Uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_STORAGE_BUCKET_NAME=bloodconnect-media-bucket
AWS_S3_REGION_NAME=ap-south-1