# ==========================================
# DJANGO CORE SETTINGS
# ==========================================
DEBUG=False
SECRET_KEY=generate_a_long_secure_random_string_here
# The backend only needs to accept traffic from its own subdomain
ALLOWED_HOSTS=api.bloodonate.org,localhost,127.0.0.1

# ==========================================
# POSTGRES DATABASE SETTINGS
# ==========================================
POSTGRES_DB=bloodonate_db
POSTGRES_USER=bloodonate_admin
POSTGRES_PASSWORD=your_very_secure_db_password
DATABASE_URL=postgres://bloodonate_admin:your_very_secure_db_password@db:5432/bloodonate_db

# ==========================================
# SECURITY & CROSS-DOMAIN (CORS) SETTINGS
# ==========================================
CORS_ALLOWED_ORIGINS=https://bloodonate.org,https://www.bloodonate.org
CSRF_TRUSTED_ORIGINS=https://bloodonate.org,https://www.bloodonate.org
FRONTEND_URL=https://bloodonate.org

# Critical for JWT cookies across subdomains
AUTH_COOKIE_DOMAIN=.bloodonate.org 

# ==========================================
# CLOUDINARY (MEDIA STORAGE)
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# EMAIL (SMTP)
# ==========================================
EMAIL_HOST=smtp.email.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=support@bloodonate.org
EMAIL_HOST_PASSWORD=your_email_password
DEFAULT_FROM_EMAIL=support@bloodonate.org